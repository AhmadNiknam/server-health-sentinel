{
  "cpu": {
    "warningPercent": 80,
    "criticalPercent": 95
  },
  "memory": {
    "warningPercent": 80,
    "criticalPercent": 95
  },
  "logicalDisk": {
    "warningFreePercent": 20,
    "criticalFreePercent": 10
  },
  "physicalDisk": {
    "warningHealthStates": [
      "Warning",
      "Degraded"
    ],
    "criticalHealthStates": [
      "Critical",
      "Unhealthy",
      "Unknown"
    ]
  },
  "uptime": {
    "warningDays": 180
  },
  "eventLogs": {
    "lookbackHours": 24,
    "maxEventsPerLog": 100,
    "monitoredLogs": [
      "System",
      "Application"
    ]
  },
  "network": {
    "minimumLinkSpeedMbps": 1000,
    "flagDisconnectedAdapters": true,
    "flagLowSpeedAdapters": true
  },
  "pendingReboot": {
    "enabled": true
  },
  "services": {
    "defaultCriticalServices": [
      "WinRM",
      "EventLog"
    ]
  }
}
